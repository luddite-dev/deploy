####################################
# 🦎 LUDDITE COMPOSE ENV 🦎 #
####################################

## Internal services (PostgreSQL, FerretDB, MinIO) bind to this IP.
## 127.0.0.1 = localhost only. Set to a Tailscale IP (e.g. 100.x.x.x)
## to access them over Tailscale without separate auth.
INTERNAL_IP=127.0.0.1

## Core container image tag from ghcr.io/luddite-dev/core
## Use "latest" for stable releases, "alpha" for bleeding-edge from main.
KOMODO_IMAGE_TAG=alpha

## Database credentials (PostgreSQL + FerretDB)
KOMODO_DATABASE_USERNAME=admin
KOMODO_DATABASE_PASSWORD=changeme

## Admin user for Komodo Core
KOMODO_INIT_ADMIN_USERNAME=admin
KOMODO_INIT_ADMIN_PASSWORD=changeme

## JWT secret — set to a random string. If empty, rotates on each restart.
KOMODO_JWT_SECRET=

## The URL users will access Komodo at.
KOMODO_HOST=http://localhost:9120

## S3 backup (MinIO) credentials
KOMODO_BACKUP_S3_BUCKET=komodo-backups
KOMODO_BACKUP_S3_ACCESS_KEY_ID=minioadmin
KOMODO_BACKUP_S3_SECRET_ACCESS_KEY=changeme

## DNS ingress (optional — needed for automatic HTTPS via Caddy + Cloudflare)
KOMODO_INGRESS_DNS_PROVIDER=cloudflare
KOMODO_INGRESS_DNS_CLOUDFLARE_API_TOKEN=file:/config/keys/cloudflare-token
KOMODO_INGRESS_DNS_BASE_DOMAIN=duti.dev
